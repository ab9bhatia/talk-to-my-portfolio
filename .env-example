# Talk to My Portfolio — local secrets (never commit)
#
# Setup:
#   1. cp .env-example .env
#   2. cp modules/portfolio/accounts.example.json modules/portfolio/accounts.json
#   3. For each enabled account in accounts.json, add matching vars below
#
# Naming rule: account "id" in JSON → UPPERCASE suffix in .env
#   accounts.json id "primary"  →  ZERODHA_API_KEY_PRIMARY
#   accounts.json id "groww1"   →  GROWW_API_KEY_GROWW1
#
# How to get broker keys: docs/broker-api-keys.md

HUB_BASE_URL=http://127.0.0.1:8000

# =============================================================================
# HTTP access (recommended for phone / LAN / any non-localhost use)
# =============================================================================
# When both are set, every page and API requires browser login (HTTP Basic Auth).
# Zerodha OAuth callback stays public so Kite redirect still works.
# PORTFOLIO_HTTP_USER=you
# PORTFOLIO_HTTP_PASSWORD=choose-a-strong-password

# Max CSV / screenshot upload size in bytes (default 10MB)
# PORTFOLIO_MAX_UPLOAD_BYTES=10485760

# =============================================================================
# Zerodha (Kite Connect) — one Kite app per Zerodha login
# =============================================================================
# 1. Log in at https://developers.kite.trade/ (same Zerodha user as the account)
# 2. Create app → copy API key + secret
# 3. Redirect URL (must match exactly on the Kite app and here):
#    http://127.0.0.1:8000/auth/zerodha/callback
# 4. In the app: /portfolio → Connect Zerodha (re-login daily ~6 AM IST)

# Account id "primary" in accounts.json (code AB on dashboard)
ZERODHA_API_KEY_PRIMARY=your_kite_api_key
ZERODHA_API_SECRET_PRIMARY=your_kite_api_secret
ZERODHA_REDIRECT_URL_PRIMARY=http://127.0.0.1:8000/auth/zerodha/callback

# Second family member — separate Kite app, same redirect URL, different id in JSON
# ZERODHA_API_KEY_MEMBER2=...
# ZERODHA_API_SECRET_MEMBER2=...
# ZERODHA_REDIRECT_URL_MEMBER2=http://127.0.0.1:8000/auth/zerodha/callback

# =============================================================================
# Groww (Trade API) — optional
# =============================================================================
# 1. Subscribe: https://groww.in/trade-api
# 2. Pick ONE auth method per account (TOTP recommended):
#
#    TOTP (recommended — no daily approval):
#      GROWW_TOTP_TOKEN_GROWW1=...
#      GROWW_TOTP_SECRET_GROWW1=...
#
#    API key + secret (may need daily approval on Groww):
#      GROWW_API_KEY_GROWW1=...
#      GROWW_API_SECRET_GROWW1=...
#
# 3. Set "enabled": true for that row in accounts.json → groww[]

# GROWW_TOTP_TOKEN_GROWW1=
# GROWW_TOTP_SECRET_GROWW1=
# GROWW_API_KEY_GROWW1=
# GROWW_API_SECRET_GROWW1=

# =============================================================================
# App behaviour (optional)
# =============================================================================
# PORTFOLIO_CACHE_TTL_SECONDS=300
# TRADING_ENABLED=false

# =============================================================================
# OpenAI (optional — nothing runs on page load by default)
# =============================================================================
# Agent (Ask button): OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# PORTFOLIO_OPENAI_API_KEY=
# PORTFOLIO_LLM_MODEL=

# Buy thesis / sector LLM on full refresh — off by default
# BUY_THESIS_LLM_ENABLED=false
# BUY_THESIS_LLM_ON_ENRICH=false
# SECTOR_LLM_ON_ENRICH=false
# Sector reference: modules/portfolio/data/sector_reference.json (auto; LLM + Yahoo + seed)

# Sarwa screenshot parsing (vision)
# SARWA_VISION_MODEL=gpt-4o-mini

# AMFI cap list
# AMFI_CAP_ENABLED=true
